{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["node", "jest"]
  },
  "include": ["frontend/**/*.ts", "frontend/**/*.tsx", "tests/**/*.ts", "cypress/**/*.ts"]
}